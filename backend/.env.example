# ============================================================
# SafeChat Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ---- App -------------------------------------------------------
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ---- Server ----------------------------------------------------
PORT=8080                        # Cloud Run expects 8080

# ---- CORS ------------------------------------------------------
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# ---- Firebase --------------------------------------------------
FIREBASE_PROJECT_ID=your-firebase-project-id
# Path to the service account JSON key (local dev only)
# In Cloud Run, use GOOGLE_APPLICATION_DEFAULT_CREDENTIALS instead
FIREBASE_CREDENTIALS_PATH=backend/credentials/firebase-admin-key.json

# ---- OpenAI (Phase 2) ------------------------------------------
# OPENAI_API_KEY=sk-...

# ---- Gemini (Phase 2) ------------------------------------------
# GEMINI_API_KEY=AIza...
