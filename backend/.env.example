# ============================================================
# SafeChat Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ---- Required --------------------------------------------------
# Path to Firebase Admin SDK JSON key.
# Relative paths are resolved from the repo root.
FIREBASE_ADMIN_KEY_PATH=backend/credentials/firebase-admin-key.json

# GCP / Firebase project ID.
GCP_PROJECT_ID=your-firebase-project-id

# ---- Optional now, required in Phase 2 -------------------------
# OpenAI Moderation API key.
# OPENAI_API_KEY=sk-...

# ---- App -------------------------------------------------------
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ---- Server ----------------------------------------------------
PORT=8080                        # Cloud Run expects 8080

# ---- CORS ------------------------------------------------------
# Comma-separated list of allowed origins.
# Defaults to localhost:8081, localhost:19006, localhost:3000 if unset.
# BACKEND_CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# ---- Firebase Storage ------------------------------------------
# Optional. Defaults to {GCP_PROJECT_ID}.firebasestorage.app if unset.
# FIREBASE_STORAGE_BUCKET=safechat-prod.firebasestorage.app

# ---- Gemini (Phase 2) ------------------------------------------
# GEMINI_API_KEY=AIza...
