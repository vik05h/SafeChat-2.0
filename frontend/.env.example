# Firebase configuration — copy to .env and fill in real values.
# Run with: flutter run --dart-define-from-file=.env
# Build with: flutter build web --dart-define-from-file=.env
#
# Get these values from:
# Firebase Console → Project Settings → Your apps

FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_APP_ID_WEB=1:your-project-number:web:your-hash
FIREBASE_APP_ID_ANDROID=1:your-project-number:android:your-hash
FIREBASE_APP_ID_IOS=1:your-project-number:ios:your-hash
FIREBASE_MESSAGING_SENDER_ID=your-project-number
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
FIREBASE_IOS_BUNDLE_ID=com.your.app
