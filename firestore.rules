rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ----------------------------------------------------------------------
    // All WRITES go through the backend (Admin SDK, which bypasses these
    // rules) so moderation always runs. The only client write is a user
    // editing their own profile document during onboarding.
    //
    // READS are deny-by-default: each collection the app reads directly
    // (real-time chat, feed, profile, follows) must opt in below. This keeps
    // backend-only collections — especially the moderation review queue, which
    // holds other users' flagged text — private by default.
    // ----------------------------------------------------------------------

    // Users + their subcollections (notifications, appeals, followers/following).
    match /users/{userId}/{document=**} {
      allow read: if request.auth != null;
    }
    match /users/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Posts + subcollections (comments, likes, views).
    match /posts/{document=**} {
      allow read: if request.auth != null;
    }

    // Chats + messages. NOTE: scoped to any authenticated user to match the
    // app's existing reads; tightening to chat participants is a future
    // hardening (see docs/MODERATION.md).
    match /chats/{document=**} {
      allow read: if request.auth != null;
    }

    // Follow graph.
    match /follows/{document=**} {
      allow read: if request.auth != null;
    }

    // Moderation review queue: backend-only. Direct client reads are limited to
    // admins (the whole queue) and the content's author (their own items);
    // everyone else is denied so flagged text never leaks.
    match /moderation_queue/{itemId} {
      allow read: if isAdmin() ||
        (request.auth != null && resource.data.author_uid == request.auth.uid);
    }

    // Raw moderation logs are never client-readable.
    match /moderation_logs/{logId} {
      allow read, write: if false;
    }

    // Default: deny. New collections must opt in above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
